# Frontend Environment Variables for Next.js
# Copy this file to .env.local and fill in your actual values

# API Configuration - Backend URL WITHOUT /api path (components will add /api/... endpoints)
NEXT_PUBLIC_API_URL=https://airswift-backend-fjt3.onrender.com

# Alternative during development:
# NEXT_PUBLIC_API_URL=http://localhost:5000

# ✅ Google OAuth Configuration
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ✅ NextAuth Configuration
# For production
NEXTAUTH_URL=https://airswift-frontend.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# For local development, use:
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=development-secret-key-32-chars-minimum-length

# Generate NEXTAUTH_SECRET with:
# openssl rand -base64 32
