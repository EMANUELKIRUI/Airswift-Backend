# ⚙️ Environment Configuration Template

# Copy this file to .env and fill in your values
# This file contains all configuration needed for the complete ATS system

# =====================================================================
# SERVER CONFIGURATION
# =====================================================================
PORT=5000
NODE_ENV=production

# =====================================================================
# DATABASE CONFIGURATION
# =====================================================================

# Sequelize (SQL Database - PostgreSQL/MySQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=airswift_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_DIALECT=postgres

# MongoDB (User Management)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/airswift?retryWrites=true&w=majority

# =====================================================================
# JWT & SECURITY
# =====================================================================
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# =====================================================================
# EMAIL SERVICE (Gmail SMTP)
# =====================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# =====================================================================
# CLOUDINARY (FILE STORAGE)
# =====================================================================
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =====================================================================
# SOCKET.IO CONFIGURATION
# =====================================================================
SOCKET_IO_ENABLED=true
SOCKET_IO_CORS_ORIGIN=https://talex-frontend.vercel.app,http://localhost:3000
SOCKET_IO_PATH=/socket.io

# =====================================================================
# FRONTEND CONFIGURATION
# =====================================================================
FRONTEND_URL=https://talex-frontend.vercel.app
NEXT_PUBLIC_API_URL=https://api.airswift.com

# =====================================================================
# OPENAI (FOR AI FEATURES)
# =====================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4

# =====================================================================
# CORS & SECURITY
# =====================================================================
ALLOWED_ORIGINS=https://talex-frontend.vercel.app,http://localhost:3000
CORS_CREDENTIALS=true

# =====================================================================
# AUDIT & LOGGING
# =====================================================================
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=90

# =====================================================================
# REDIS (Optional - for session management)
# =====================================================================
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# =====================================================================
# PAYMENT PROCESSING (Optional)
# =====================================================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# =====================================================================
# AWS (Optional - for S3 file storage alternative)
# =====================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=airswift-files

# =====================================================================
# MONITORING & ANALYTICS (Optional)
# =====================================================================
SENTRY_DSN=https://xxxxxxxxxxxx@sentry.io/xxxxxxxxxxxx
ANALYTICS_ENABLED=true

# =====================================================================
# RATE LIMITING
# =====================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================================
# DEBUG MODE
# =====================================================================
DEBUG=false
LOG_LEVEL=info

# =====================================================================
# Features Configuration
# =====================================================================

# AI CV Scoring
ENABLE_CV_SCORING=true
CV_SCORE_MIN_THRESHOLD=40

# Real-time Updates
ENABLE_SOCKET_IO=true
SOCKET_IO_RECONNECTION_DELAY=5000

# Email Notifications
ENABLE_EMAIL_NOTIFICATIONS=true
SEND_EMAILS_ON_STATUS_CHANGE=true
SEND_INTERVIEW_REMINDERS=true

# Analytics
ENABLE_ANALYTICS=true
ANALYTICS_UPDATE_INTERVAL=300000

# Audit Logging
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_LEVEL=info

# =====================================================================
# Admin Credentials (Optional - for testing)
# =====================================================================
DEFAULT_ADMIN_EMAIL=admin@talex.com
DEFAULT_ADMIN_PASSWORD=Admin123!

# =====================================================================
# Timezone & Locale
# =====================================================================
TIMEZONE=UTC
LOCALE=en-US

# =====================================================================
# IMPORTANT NOTES
# =====================================================================

# 🔐 SECURITY:
# - NEVER commit this file to version control
# - Use different values for dev/staging/production
# - Rotate secrets regularly
# - Use strong, unique values
# - Store in secure secret manager (AWS Secrets Manager, Vault, etc.)

# 📧 EMAIL SETUP:
# Gmail:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Create App Password: https://support.google.com/accounts/answer/185833
#   4. Use the 16-character password above

# 🗄️ DATABASE:
# - For production, use managed databases (AWS RDS, MongoDB Atlas, etc.)
# - Ensure proper backups and monitoring
# - Use SSL/TLS for connections
# - Restrict network access

# 🔑 API KEYS:
# - Keep separate keys for dev/staging/production
# - Rotate keys regularly
# - Monitor for unauthorized usage

# 📊 MONITORING:
# - Enable logging for production
# - Set up alerts for critical errors
# - Monitor performance metrics
# - Track API usage

# =====================================================================

